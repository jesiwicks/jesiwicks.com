# Cloudflare Workers Static Assets — cache headers
# Goal: fix 7% edge cache rate by overriding the default
# "Cache-Control: public, max-age=0, must-revalidate" that Cloudflare
# applies to every static asset response.

# Long-lived immutable cache for self-hosted fonts
# Filenames are stable, browsers can hold these for a year
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# 30-day cache for images (OG cards, avatar, guide OG images)
/*.jpg
  Cache-Control: public, max-age=2592000
/*.jpeg
  Cache-Control: public, max-age=2592000
/*.png
  Cache-Control: public, max-age=2592000
/*.webp
  Cache-Control: public, max-age=2592000
/*.gif
  Cache-Control: public, max-age=2592000
/*.svg
  Cache-Control: public, max-age=2592000
/*.ico
  Cache-Control: public, max-age=2592000

# HTML and everything else: browser always revalidates (deploys go
# live instantly), but Cloudflare's edge caches for 1 hour with
# stale-while-revalidate for international visitors
/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600, stale-while-revalidate=86400
